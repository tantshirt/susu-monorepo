# Reference app environment variables
# Copy this file to apps/reference/.env.local and fill in real values for
# local development. All keys are validated at startup via lib/env.ts.
#
# Demo script env (root `pnpm susu:demo`, not read by Next.js):
#   SUSU_DEMO_RPC_URL, SUSU_DEMO_KEYPAIR_PATH, SUSU_DEMO_SKIP_PREFLIGHT,
#   SUSU_DEMO_SKIP_AIRDROP — see docs/demo-setup.md

# Helius RPC endpoint (or any other Solana RPC provider)
NEXT_PUBLIC_HELIUS_RPC_URL=https://api.devnet.solana.com

# Privy application id — 25 characters from https://dashboard.privy.io (required for login).
# Do not use clw0000000000000000000000; lib/env.ts rejects that placeholder.
NEXT_PUBLIC_PRIVY_APP_ID=

# Convex deployment URL (https://dashboard.convex.dev)
NEXT_PUBLIC_CONVEX_URL=https://example-aardvark-123.convex.cloud

# Susu program id (base58)
NEXT_PUBLIC_PROGRAM_ID=Susu1111111111111111111111111111111111111111

# Solana cluster (one of: mainnet-beta | devnet | testnet | localnet)
NEXT_PUBLIC_CLUSTER=devnet

# Whether the Sphere on-ramp surface is enabled (true|false)
NEXT_PUBLIC_SPHERE_ENABLED=false
