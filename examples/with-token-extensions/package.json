{
  "name": "@susu-examples/with-token-extensions",
  "private": true,
  "type": "module",
  "scripts": {
    "prestart": "pnpm --filter @susu/sdk build",
    "start": "tsx src/index.ts",
    "prebuild": "pnpm --filter @susu/sdk build",
    "build": "tsc -p tsconfig.json",
    "pretest": "pnpm --filter @susu/sdk build",
    "test": "vitest run --exclude dist/**",
    "test:e2e": "PNPM_TEST_E2E=1 vitest run tests/e2e.test.ts"
  },
  "dependencies": {
    "@solana-program/token-2022": "^0.7.0",
    "@solana/kit": "^5.0.0",
    "@solana/web3-compat": "^0.0.21",
    "@susu/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "tsx": "^4.21.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.5"
  }
}
