{
  "name": "@susu-examples/with-privy",
  "private": true,
  "type": "module",
  "scripts": {
    "prestart": "pnpm --filter @susu/sdk build",
    "start": "tsx src/index.ts",
    "prebuild": "pnpm --filter @susu/sdk build",
    "build": "tsc -p tsconfig.json",
    "pretest": "pnpm --filter @susu/sdk build",
    "test": "vitest run tests --exclude dist/**"
  },
  "dependencies": {
    "@privy-io/node": "0.18.0",
    "@solana/kit": "^5.0.0",
    "@solana/web3-compat": "^0.0.21",
    "@susu/sdk": "workspace:*",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.40",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.5"
  }
}
